        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="120" SortOrder="1">The Pension Benefit Guaranty Corporation protects the retirement incomes of American workers in private-sector defined benefit pension plans.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
