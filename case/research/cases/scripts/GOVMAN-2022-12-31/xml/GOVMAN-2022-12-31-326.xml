        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="162" SortOrder="1">The Employee Benefits Security Administration assures the security of the retirement, health, and other workplace related benefits of American workers and their families.</Paragraph>
