        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="145" SortOrder="1">The Organization of American States seeks an order of peace and justice among its member states, promotes their solidarity and strengthens their collaboration, and defends their sovereignty, territorial integrity, and independence.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
