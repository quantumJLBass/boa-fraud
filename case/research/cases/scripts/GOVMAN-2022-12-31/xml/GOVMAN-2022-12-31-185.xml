        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="64" SortOrder="1">The Legal Services Corporation promotes equal access to justice and provides civil legal assistance to low-income persons.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
