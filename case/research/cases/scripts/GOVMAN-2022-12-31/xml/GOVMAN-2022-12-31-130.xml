        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="34" SortOrder="1">The Central Intelligence Agency collects, evaluates, and disseminates vital information on economic, military, political, scientific, and other developments abroad to safeguard national security.</Paragraph>
