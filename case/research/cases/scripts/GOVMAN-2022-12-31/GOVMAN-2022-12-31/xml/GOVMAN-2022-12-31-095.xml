        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="33" SortOrder="1">The United States Sentencing Commission develops sentencing guidelines and policies for the Federal court system.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
