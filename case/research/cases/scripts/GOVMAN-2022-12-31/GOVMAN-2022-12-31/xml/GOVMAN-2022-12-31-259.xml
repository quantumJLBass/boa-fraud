        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="169" SortOrder="1">The Bureau of Industry and Security ensures an effective export control and treaty compliance system and promotes the Nation's strategic leadership in technology to strengthen national security, advance U.S. foreign policy, and achieve economic objectives.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
