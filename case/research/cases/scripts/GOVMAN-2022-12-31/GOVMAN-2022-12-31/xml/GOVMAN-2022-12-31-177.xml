        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="121" SortOrder="1">The Social Security Administration manages the retirement, survivors, and disability insurance programs that are known as Social Security; it administers the Supplemental Security Income program for the aged, blind, and disabled; and it assigns Social Security numbers to U.S. citizens and maintains earnings records based on those numbers.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
