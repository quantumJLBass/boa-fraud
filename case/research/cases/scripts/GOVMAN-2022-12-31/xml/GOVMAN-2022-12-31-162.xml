        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="49" SortOrder="1">The National Transportation Safety Board investigates accidents, conducts studies, and makes recommendations on safety to Government agencies, the transportation industry, and others.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
