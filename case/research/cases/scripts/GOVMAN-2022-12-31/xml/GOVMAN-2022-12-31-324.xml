                <Activity ProgramAndActivitiesId="1216" SortOrder="1">
                    <Heading/>
                    <Details>
                        <Detail SortOrder="1" TypeOfProgramAndActivitiesDetailsId="2376">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://www.dol.gov/agencies/ilab/our-work</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>The Bureau of International Labor Affairs (ILAB)
                                        promotes a fair global playing field for workers and
                                        businesses in the United States by enforcing trade
                                        commitments; strengthening labor standards; and combating
                                        international child labor, forced labor, and human
                                        trafficking. ILAB combines trade and labor monitoring and
                                        enforcement, policy engagement, technical assistance, and
                                        research to carry out the Department of Labor's
                                        international responsibilities.</Paragraph>
                        </Detail>
                    </Details>
                </Activity>
            </ProgramAndActivity>
