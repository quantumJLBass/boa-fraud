                <Activity ProgramAndActivitiesId="582" SortOrder="16">
                    <Heading>State Program Grants</Heading>
                    <Details>
                        <Detail SortOrder="1" TypeOfProgramAndActivitiesDetailsId="922">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://www.imls.gov/grants/grants-states</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>The Grants to States program is the largest Federal
                                        source of funding to support library services in the United
                                        States. The IMLS uses a population-based formula to
                                        distribute annual grants among the State Library
                                        Administrative Agencies—official agencies charged by law
                                        with the extension and development of library services. Each
                                        year, thousands of Grants to States projects promote the
                                        priorities and assist the purposes of the Library Services
                                        and Technology Act.</Paragraph>
                        </Detail>
                    </Details>
