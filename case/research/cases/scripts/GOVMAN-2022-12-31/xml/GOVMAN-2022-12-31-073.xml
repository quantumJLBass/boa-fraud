            <ProgramAndActivity ProgramAndActivitiesId="528" SortOrder="2">
                <FooterDetails>
                    <Email/>
                    <Footer/>
                    <WebAddress/>
                </FooterDetails>
                <MainParagraph>The Architect of the Capitol serves the Congress and Supreme Court in
                    its capacity as the builder and steward of the landmark buildings and grounds of
                    Capitol Hill. AOC employees preserve and maintain the art, historic buildings,
                    monuments, and gardens on the Capitol campus. Comprising more than 2,000
                    employees and providing around-the-clock service, the AOC team creates a safe
                    environment and inspiring experiences for those who visit or work on Capitol
                    Hill.</MainParagraph>
                <PointOfContact/>
                <ProgramName>ACTIVITIES</ProgramName>
            </ProgramAndActivity>
            <ProgramAndActivity ProgramAndActivitiesId="529" SortOrder="3">
                <FooterDetails>
                    <Email/>
                    <Footer/>
                    <WebAddress>https://www.aoc.gov/defining-aoc</WebAddress>
                </FooterDetails>
                <MainParagraph>The agency oversees the operations and care of more than 17.4 million
                    square feet of facilities, 580 acres of grounds, and thousands of works of art.
                    The Capitol campus accommodates 30,000 daily occupants and hosts more than 3
                    million visitors annually.</MainParagraph>
                <PointOfContact/>
                <ProgramName/>
            </ProgramAndActivity>
