        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="73" SortOrder="1">The Administrative Conference of the United States develops recommendations for improving the fairness and effectiveness of procedures by which Federal agencies administer regulatory, benefit, and other Government programs.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
