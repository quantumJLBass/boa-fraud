        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="113" SortOrder="1">The Department of Education ensures equal access to education; promotes educational excellence; and administers, coordinates, and makes policy for most Federal assistance to education with the aim of raising levels of student achievement and readiness for the global future.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
