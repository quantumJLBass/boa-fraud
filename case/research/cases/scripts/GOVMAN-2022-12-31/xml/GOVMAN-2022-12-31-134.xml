        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="107" SortOrder="1">The Defense Nuclear Facilities Safety Board identifies the nature and consequences of public health and safety threats at the Department of Energy's defense nuclear facilities, elevates awareness of and information on such threats to the highest levels of governmental authority, and keeps the public informed.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
