                    <Heading>STATUTORY AND REGULATORY AUTHORITIES</Heading>
                    <Details>
                        <Detail SortOrder="1" TypeOfProgramAndActivitiesDetailsId="3238">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://uscode.house.gov/view.xhtml?path=/prelim@title12/chapter1&amp;edition=prelim</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>Statutory material affecting the Comptroller of the
                                        Currency has been consolidated and codified in the United
                                        States Code (U.S.C.). This material has been assigned to the
                                        first chapter, sections 1–16, of 12 U.S.C.</Paragraph>
                        </Detail>
                        <Detail SortOrder="2" TypeOfProgramAndActivitiesDetailsId="3239">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://www.ecfr.gov/cgi-bin/text-idx?SID=9239dee7caf69de5910e02babdd4547c&amp;mc=true&amp;tpl=/ecfrbrowse/Title12/12chapterI.tpl</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>Rules and regulations that are associated with the
                                        Comptroller of the Currency have been consolidated and
                                        codified in the Code of Federal Regulations (CFR). These
                                        rules and regulations have been assigned to the first
                                        chapter, parts 1–199, of 12CFR.</Paragraph>
                        </Detail>
                    </Details>
                </Activity>
            </ProgramAndActivity>
            <ProgramAndActivity ProgramAndActivitiesId="573" SortOrder="3">
                <FooterDetails>
                    <Email/>
                    <Footer/>
                    <WebAddress/>
                </FooterDetails>
                <MainParagraph/>
                <PointOfContact/>
