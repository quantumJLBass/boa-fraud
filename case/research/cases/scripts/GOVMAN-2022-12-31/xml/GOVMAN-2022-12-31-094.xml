        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="26" SortOrder="1">The Federal Judicial Center is the judicial branch's agency for policy research and continuing education.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
