        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="108" SortOrder="1">The Federal Deposit Insurance Corporation preserves and promotes public confidence in U.S. financial institutions by insuring bank and thrift deposits, examining State-chartered banks, and liquidating assets of failed institutions.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
