                <Activity ProgramAndActivitiesId="1171" SortOrder="14">
                    <Heading>Transit in Parks</Heading>
                    <Details>
                        <Detail SortOrder="1" TypeOfProgramAndActivitiesDetailsId="2079">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>http://www.fta.dot.gov/transitinparks</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>The Paul S. Sarbanes Transit in Parks Program
                                        provides funding for alternative transportation projects in
                                        and around National Parks and other Federal recreation
                                        areas. Alternative transportation includes bicycle, ferry,
                                        pedestrian trail, shuttle bus, and other forms of public or
                                        nonmotorized transportation. These projects reduce
                                        congestion, protect sensitive natural and cultural
                                        treasures, and enhance visitor experience. Funding is
                                        awarded through a competitive process to units of Federal
                                        land management agencies and to State, local and tribal
                                        government agencies.</Paragraph>
                        </Detail>
                        <Detail SortOrder="2" TypeOfProgramAndActivitiesDetailsId="2548">
                            <FooterDetails>
