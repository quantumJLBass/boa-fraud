        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="167" SortOrder="1">The Congressional Research Service provides high quality research, analysis, information, and confidential consultation to help the U.S. Congress carry out its legislative, representational and oversight duties.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
