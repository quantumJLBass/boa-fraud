        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="31" SortOrder="1">The Alcohol and Tobacco Tax and Trade Bureau enforces the laws regulating alcohol production, importation, and wholesale businesses; tobacco manufacturing and importing businesses; and alcohol labeling and advertising.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
