        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="39" SortOrder="1">The Federal Housing and Finance Agency ensures that the housing Government-Sponsored Enterprises operate safely and soundly and serve as a reliable source of liquidity and funding for housing finance and community investment.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
