                <Activity ProgramAndActivitiesId="208" SortOrder="1">
                    <Heading/>
                    <Details>
                        <Detail SortOrder="1" TypeOfProgramAndActivitiesDetailsId="303">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://www.govinfo.gov/content/pkg/STATUTE-72/pdf/STATUTE-72-Pg731.pdf</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>The Federal Aviation Administration (FAA), formerly
                                        the Federal Aviation Agency, was established by the Federal
                                        Aviation Act of 1958 (72 Stat. 731).</Paragraph>
                        </Detail>
                        <Detail SortOrder="2" TypeOfProgramAndActivitiesDetailsId="3251">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://www.govinfo.gov/content/pkg/STATUTE-80/pdf/STATUTE-80-Pg931.pdf</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>The Administration became a component of the
                                        Department of Transportation in 1967, pursuant to the
                                        Department of Transportation Act (49 U.S.C.
                                        106).</Paragraph>
                        </Detail>
                        <Detail SortOrder="3" TypeOfProgramAndActivitiesDetailsId="3253">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://www.faa.gov/about/office_org/</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>The FAA posts an organizational chart on its
                                        "Offices" web page in Portable Document Format (PDF) for
                                        viewing and downloading.</Paragraph>
                        </Detail>
                    </Details>
                </Activity>
