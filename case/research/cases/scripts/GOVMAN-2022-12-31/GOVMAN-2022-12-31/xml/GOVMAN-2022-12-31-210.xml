                                <Email/>
                                <Footer/>
                                <WebAddress>https://www.imls.gov/grants/available/native-american-library-services-enhancement-grants</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>These grants to federally recognized tribes expand
                                        services for access to information, learning, and
                                        partnerships.</Paragraph>
                        </Detail>
                    </Details>
