        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="111" SortOrder="1">The Federal Trade Commission protects America's consumers and enforces laws prohibiting anticompetitive, deceptive, or unfair business practices.</Paragraph>
                <FooterDetails>
