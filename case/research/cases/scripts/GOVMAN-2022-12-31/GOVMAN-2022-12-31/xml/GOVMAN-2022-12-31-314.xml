                    <Footer/>
                    <WebAddress>https://www.insurekidsnow.gov</WebAddress>
                </FooterDetails>
                <Header>Insurance for Children</Header>
                <Paragraph>Millions of children and teens qualify for free or low-cost health and dental coverage through the Children's Health Insurance Program and the Medicaid program.</Paragraph>
            </EntitySourceOfInformation>
            <EntitySourceOfInformation EntitySourceOfInformationId="8083" SortOrder="14">
