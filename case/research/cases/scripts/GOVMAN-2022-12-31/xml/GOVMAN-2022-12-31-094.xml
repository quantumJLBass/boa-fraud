                    <Footer/>
                    <WebAddress>https://www.fjc.gov/history/courthouses</WebAddress>
                </FooterDetails>
                <Header/>
                <Paragraph>Hundreds of images of historic Federal courthouses and other buildings that have served as the meeting places of Federal courts are available online.</Paragraph>
            </EntitySourceOfInformation>
            <EntitySourceOfInformation EntitySourceOfInformationId="3144" SortOrder="11">
                <FooterDetails>
                    <Email/>
                    <Footer/>
                    <WebAddress>https://www.fjc.gov/history/timeline</WebAddress>
                </FooterDetails>
                <Header/>
                <Paragraph>Timelines of the structure of the Federal courts, jurisdiction of the Federal courts, administration of the Federal courts, and cases that shaped the them are posted online.</Paragraph>
            </EntitySourceOfInformation>
            <EntitySourceOfInformation EntitySourceOfInformationId="3146" SortOrder="12">
                <FooterDetails>
                    <Email/>
                    <Footer/>
