        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="46" SortOrder="1">The Commodity Futures Trading Commission avoids systemic risk; fosters open, transparent, competitive, and financially sound markets; and protects the market users and their funds, consumers, and the public from fraud, manipulation, and abusive practices related to derivatives and other products that are subject to the Commodity Exchange Act.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
