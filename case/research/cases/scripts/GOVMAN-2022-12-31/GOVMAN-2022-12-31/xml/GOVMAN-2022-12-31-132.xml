        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="59" SortOrder="1">The Consumer Product Safety Commission protects the public by reducing the risk of injury and death from consumer products.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
