        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="43" SortOrder="1">The Railroad Retirement Board administers comprehensive retirement-survivor and unemployment-sickness benefit programs for the Nation's railroad workers and their families.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
