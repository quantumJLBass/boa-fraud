        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="148" SortOrder="1">The Women's Bureau develops policies and standards and conducts inquiries to safeguard the interests of working women, to advocate for their equality and the economic security of their families, and to promote quality work environments.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
