        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="166" SortOrder="1">The Wage and Hour Division protects and enhances the welfare of the Nation's workers by promoting and achieving compliance with labor standards.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
