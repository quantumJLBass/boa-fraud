        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="165" SortOrder="1">The Veterans' Employment and Training Service helps America's veterans, servicemembers, and their spouses who are eligible prepare for careers; provides them with employment resources and expertise; protects their employment rights; and promotes their employment opportunities.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
