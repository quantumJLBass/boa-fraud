        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="159" SortOrder="1">The Bureau of Alcohol, Tobacco, Firearms and Explosives protects the public from crimes involving arson, explosives, firearms, and the diversion of alcohol and tobacco products; regulates lawful commerce in explosives and firearms; and supports law enforcement, public safety, and industry partners worldwide.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
