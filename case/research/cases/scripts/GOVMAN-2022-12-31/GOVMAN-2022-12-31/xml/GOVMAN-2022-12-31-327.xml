        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="163" SortOrder="1">The Employment and Training Administration helps the U.S. labor market function more efficiently by providing job training, employment, labor market information, and income maintenance services.</Paragraph>
