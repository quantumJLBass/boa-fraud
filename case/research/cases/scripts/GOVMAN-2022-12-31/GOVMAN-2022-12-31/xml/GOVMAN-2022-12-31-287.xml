                    <Heading>STATUTORY AND REGULATORY AUTHORITIES</Heading>
                    <Details>
                        <Detail SortOrder="1" TypeOfProgramAndActivitiesDetailsId="2986">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://uscode.house.gov/view.xhtml?path=/prelim@title6/chapter1/subchapter11&amp;edition=prelim</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>"Subchapter XI—Department of Justice
                                                Divisions" is part of "Chapter 1—Homeland Security
                                                Organization" in 6 U.S.C. Parts 531–533 contain
                                                codified statutory material associated with the
                                                transfer of the ATFE to the Department of
                                                Justice.</Paragraph>
                        </Detail>
                        <Detail SortOrder="2" TypeOfProgramAndActivitiesDetailsId="2987">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://www.ecfr.gov/cgi-bin/text-idx?SID=c5bb1cb9dbe3c7d2134a728d6b30c7ea&amp;mc=true&amp;tpl=/ecfrbrowse/Title27/27chapterII.tpl</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>Rules and regulations that affect firearms
                                                and ammunition, explosives, alcohol and tobacco, and
                                                explosive license and permit proceedings are
                                                codified in chapter II, parts 400–799, of 27
                                                CFR.</Paragraph>
                        </Detail>
                    </Details>
                </Activity>
            </ProgramAndActivity>
            <ProgramAndActivity ProgramAndActivitiesId="552" SortOrder="3">
                <FooterDetails>
                    <Email/>
