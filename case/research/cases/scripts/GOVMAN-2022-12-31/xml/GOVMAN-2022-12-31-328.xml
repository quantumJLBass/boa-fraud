        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="164" SortOrder="1">The Mine Safety and Health Administration works to prevent mine-related deaths, illnesses, and injuries and promotes safe and healthy work environments.</Paragraph>
