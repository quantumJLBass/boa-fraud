        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="152" SortOrder="1">The Bureau of Indian Education provides educational opportunities for eligible American Indian and Alaska Native elementary, secondary, and postsecondary students from federally recognized Tribes</Paragraph>
                <FooterDetails>
