                <Activity ProgramAndActivitiesId="1218" SortOrder="1">
                    <Heading/>
                    <Details>
                        <Detail SortOrder="1" TypeOfProgramAndActivitiesDetailsId="2381">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://www.dol.gov/agencies/ebsa/about-ebsa/about-us/what-we-do</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>The Employee Benefits Security Administration (EBSA)
                                        educates and assists the over 154 million participants in
                                        and beneficiaries of approximately 710,000 private
                                        retirement plans, 2.4 million health plans, and similar
                                        numbers of other welfare benefit plans. The EBSA balances
                                        proactive enforcement with compliance assistance and
                                        supports enrollees and beneficiaries by developing effective
                                        regulations; assisting and educating fiduciaries, plan
                                        sponsors, service providers, and workers; and enforcing the
                                        law.</Paragraph>
                        </Detail>
                    </Details>
                </Activity>
            </ProgramAndActivity>
