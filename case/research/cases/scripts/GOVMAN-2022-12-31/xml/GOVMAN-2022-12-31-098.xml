                <Activity ProgramAndActivitiesId="1340" SortOrder="2">
                    <Heading>REGULATORY AUTHORITIES</Heading>
                    <Details>
                        <Detail SortOrder="1" TypeOfProgramAndActivitiesDetailsId="2956">
                            <FooterDetails>
