        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="109" SortOrder="1">The Federal Mediation and Conciliation Service helps labor and management resolve disputes in industries affecting commerce, offers training in cooperative processes to promote workplace stability and economic growth, and provides alternative dispute resolution services, training, negotiated rulemaking, and public policy facilitation to government entities.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
