                <Activity ProgramAndActivitiesId="254" SortOrder="1">
                    <Heading/>
                    <Details>
                        <Detail SortOrder="1" TypeOfProgramAndActivitiesDetailsId="364">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://www.transit.dot.gov/about-fta</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>The Federal Transit Administration (FTA), formerly
                                        the Urban Mass Transportation Administration, was
                                        established as an operating administration of the U.S.
                                        Department of Transportation by section 1 of Reorganization
                                        Plan No. 2 of 1968 (5 U.S.C. app. 1), effective July 1,
                                        1968. The FTA helps America's communities by developing
                                        improved public transportation and providing financial
                                        assistance to State and local governments to finance public
                                        transportation systems and carry out national transit goals
                                        and policy.</Paragraph>
                        </Detail>
                    </Details>
                </Activity>
            </ProgramAndActivity>
