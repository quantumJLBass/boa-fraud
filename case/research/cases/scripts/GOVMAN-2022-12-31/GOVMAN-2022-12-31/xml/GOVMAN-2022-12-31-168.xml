        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="88" SortOrder="1">The United States Office of Special Counsel investigates allegations of certain activities prohibited by civil service laws, rules, or regulations and litigates before the Merit Systems Protection Board.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
