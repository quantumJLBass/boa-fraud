        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="94" SortOrder="1">The National Endowment for the Humanities supports research, education, preservation, and public programs in the humanities.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
