        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="90" SortOrder="1">The Peace Corps gives the peoples of host countries increased access to volunteers who are qualified, skilled, and trained, and it strengthens mutual understanding between Americans and the peoples of the countries served.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
