        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="115" SortOrder="1">The National Labor Relations Board remedies unfair labor practices and safeguards employees' rights to organize and to determine whether to have unions as their bargaining representative.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
