        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="86" SortOrder="1">The Nuclear Regulatory Commission licenses and regulates civilian use of nuclear energy to protect public health and safety and the environment.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
