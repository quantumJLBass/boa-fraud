        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="55" SortOrder="1">The Office of National Drug Control Policy helps the President establish his National Drug Control Strategy objectives, priorities, and policies and makes budget, program, and policy recommendations affecting National Drug Control Program agencies.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
