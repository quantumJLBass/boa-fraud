                    <Details>
                        <Detail SortOrder="1" TypeOfProgramAndActivitiesDetailsId="1111">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://www.wilsoncenter.org/about-the-wilson-center</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>Created by an Act of Congress in 1968, the Woodrow
                                        Wilson International Center for Scholars is a national,
                                        living memorial honoring the legacy of President Woodrow
                                        Wilson. The Wilson Center, headquartered in Washington, DC,
                                        and supported by both public and private funds, provides a
                                        strictly nonpartisan space for scholars and policymakers to
                                        interact. By conducting relevant, timely research and
                                        promoting dialogue from diverse perspectives, the Center
                                        works to address critical current and emerging challenges
                                        confronting the United States and the world.</Paragraph>
                        </Detail>
                    </Details>
                </Activity>
