        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="99" SortOrder="1">The Federal Election Commission provides public disclosure of campaign finance activities and ensures compliance with campaign finance laws and regulations.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
