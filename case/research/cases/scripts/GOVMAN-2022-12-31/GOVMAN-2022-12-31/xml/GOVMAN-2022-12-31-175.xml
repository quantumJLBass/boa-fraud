        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="62" SortOrder="1">The Selective Service System supplies the Armed Forces with manpower in an emergency and operates an Alternative Service Program for men classified as conscientious objectors.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
