        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="117" SortOrder="1">The Occupational Safety and Health Review Commission ensures the timely and fair resolution of cases involving the alleged exposure of American workers to unsafe or unhealthy working conditions.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
