        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="36" SortOrder="1">The Department of Commerce promotes the Nation's domestic and international trade, economic growth, and technological advancement by fostering free enterprise worldwide, supporting fair trade, compiling social and economic statistics, protecting Earth's physical resources, granting patents and registering trademarks, and assisting small and minority-owned businesses.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
