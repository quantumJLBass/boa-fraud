        <ProgramAndActivities>
            <ProgramAndActivity ProgramAndActivitiesId="87" SortOrder="1">
                <FooterDetails>
                    <Email/>
                    <Footer/>
                    <WebAddress/>
                </FooterDetails>
                <MainParagraph/>
                <PointOfContact/>
