        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="119" SortOrder="1">The Overseas Private Investment Corporation promotes economic growth and job opportunities both at home and abroad by encouraging U.S. private investment in developing countries and emerging markets.</Paragraph>
