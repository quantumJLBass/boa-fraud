        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="97" SortOrder="1">The Federal Mine Safety and Health Review Commission ensures compliance with occupational safety and health standards in the Nation's surface and underground coal, metal, and nonmetal mines.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
