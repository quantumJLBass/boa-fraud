                <Activity ProgramAndActivitiesId="524" SortOrder="1">
                    <Heading>ESTABLISHMENT AND ORGANIZATION</Heading>
                    <Details>
                        <Detail SortOrder="1" TypeOfProgramAndActivitiesDetailsId="817">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress/>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>The Federal Trade Commission (FTC) was established in 1914 by
                                the Federal Trade Commission Act (15 U.S.C. 41-58). The Commission
                                comprises five members whom the President appoints with the advice
                                and consent of the Senate for 7-year terms. No more than three of
                                the Commissioners may be members of the same political party. The
                                President designates one of them as Chair of the Commission to
                                oversee its administrative management.</Paragraph>
                        </Detail>
                        <Detail SortOrder="2" TypeOfProgramAndActivitiesDetailsId="3214">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://www.ecfr.gov/cgi-bin/text-idx?SID=1eef003b863924b104aa3a379a1a8b5c&amp;mc=true&amp;node=pt16.1.0&amp;rgn=div5</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>The FTC's statement of organization has been codified in the
                                Code of Federal Regulations (CFR) and assigned to Part 0 of 16
                                CFR.</Paragraph>
                        </Detail>
                        <Detail SortOrder="3" TypeOfProgramAndActivitiesDetailsId="3213">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://www.ftc.gov/system/files/attachments/about-ftc/ftc_org_chart_0.pdf</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>The FTC posts its organizational chart (JUN 2021) in Portable
                                Document Format for viewing and downloading.</Paragraph>
                        </Detail>
                    </Details>
                </Activity>
            </ProgramAndActivity>
            <ProgramAndActivity ProgramAndActivitiesId="250" SortOrder="2">
                <FooterDetails>
                    <Email/>
                    <Footer/>
                    <WebAddress/>
                </FooterDetails>
                <MainParagraph/>
                <PointOfContact/>
