        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="75" SortOrder="1">The Federal Communications Commission regulates interstate and foreign communications by radio, television, wire, satellite, and cable.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
