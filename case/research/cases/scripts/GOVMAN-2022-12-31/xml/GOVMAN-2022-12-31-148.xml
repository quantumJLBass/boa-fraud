                <Activity ProgramAndActivitiesId="745" SortOrder="1">
                    <Heading/>
                    <Details>
                        <Detail SortOrder="1" TypeOfProgramAndActivitiesDetailsId="1151">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://uscode.house.gov/view.xhtml?path=/prelim@title5/part3/subpartG/chapter84&amp;edition=prelim</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>Statutory material that is associated with the Federal
                                Employees' Retirement System is codified and has been assigned to
                                Chapter 84 (sections 8401–8480) of 5 U.S.C.</Paragraph>
                        </Detail>
                        <Detail SortOrder="2" TypeOfProgramAndActivitiesDetailsId="1152">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://uscode.house.gov/view.xhtml?req=granuleid:USC-prelim-title5-section8351&amp;num=0&amp;edition=prelim</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>Statutory material affecting "Government Organization and
                                Employees" is codified and has been assigned to 5 U.S.C. The heading
                                "Participation in the Thrift Savings Plan" describes section
                                8351.</Paragraph>
                        </Detail>
                        <Detail SortOrder="3" TypeOfProgramAndActivitiesDetailsId="3196">
                            <FooterDetails>
                                <Email/>
                                <Footer/>
                                <WebAddress>https://www.ecfr.gov/cgi-bin/text-idx?SID=381bec672672e2c9d813a8633bd18d00&amp;mc=true&amp;tpl=/ecfrbrowse/Title05/5cfrv3_02.tpl#1600</WebAddress>
                            </FooterDetails>
                            <Heading/>
                            <Paragraph>Rules and regulations that govern the FRTIB are codified and
                                have been assigned to Chapter VI (parts 1600–1699) of 5
                                CFR.</Paragraph>
                        </Detail>
                    </Details>
                </Activity>
            </ProgramAndActivity>
            <ProgramAndActivity ProgramAndActivitiesId="566" SortOrder="3">
