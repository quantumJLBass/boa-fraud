                            </FooterDetails>
                            <Heading/>
                            <Paragraph>These grants help museum professionals address the
                                        challenges and needs of their field. Projects supported by
                                        these grants promote innovation and collaboration and
                                        typically produce results that broadly affect the museum
                                        field.</Paragraph>
                        </Detail>
                    </Details>
                </Activity>
                <Activity ProgramAndActivitiesId="588" SortOrder="9">
                    <Heading>National Medal for Museum and Library Service</Heading>
                    <Details>
                        <Detail SortOrder="1" TypeOfProgramAndActivitiesDetailsId="928">
                            <FooterDetails>
