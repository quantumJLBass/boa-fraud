        <MissionStatement>
            <Heading/>
            <Record>
                <Paragraph MissionStatmentId="161" SortOrder="1">The Bureau of Labor Statistics measures labor market activity, working conditions, price changes, and productivity in the Nation's economy to support decision making in both the public and private sectors.</Paragraph>
                <FooterDetails>
                    <Footer/>
                </FooterDetails>
            </Record>
        </MissionStatement>
